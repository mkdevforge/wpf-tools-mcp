<Window x:Class="WpfPilot.TestApp.BindingErrors.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="WpfPilot BindingErrors TestApp"
        Width="900"
        Height="650"
        ResizeMode="NoResize"
        Topmost="True"
        WindowStartupLocation="Manual"
        Left="100"
        Top="100"
        Background="White"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="WpfPilot.TestApp.BindingErrors — Binding Error Feed"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Margin="0,0,0,16" />

        <StackPanel Grid.Row="1" Width="520">
            <TextBlock Text="The TextBlock below intentionally binds to a missing property to trigger BindingStatus.PathError."
                       Foreground="Gray"
                       Margin="0,0,0,12" />

            <TextBlock AutomationProperties.AutomationId="BindingErrors_BrokenText"
                       FontSize="16"
                       Text="{Binding MissingProperty}"
                       Margin="0,0,0,12" />

            <TextBlock Text="A valid binding for contrast:"
                       Foreground="Gray"
                       Margin="0,0,0,8" />

            <TextBox AutomationProperties.AutomationId="BindingErrors_OkTextBox"
                     Width="260"
                     Text="{Binding OkText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,12" />
        </StackPanel>
    </Grid>
</Window>

