<Window x:Class="WpfPilot.TestApp.CustomControls.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfPilot.TestApp.CustomControls"
        mc:Ignorable="d"
        Title="WpfPilot CustomControls TestApp"
        Width="900"
        Height="650"
        ResizeMode="NoResize"
        Topmost="True"
        WindowStartupLocation="Manual"
        Left="100"
        Top="100"
        Background="White"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="WpfPilot.TestApp.CustomControls — Custom controls"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Margin="0,0,0,16" />

        <StackPanel Grid.Row="1" Width="520">
            <local:ClickableCard AutomationProperties.AutomationId="Custom_ClickableCard"
                                 Clicked="ClickableCard_Clicked"
                                 Margin="0,0,0,12" />

            <TextBlock x:Name="StatusText"
                       AutomationProperties.AutomationId="Custom_Status"
                       Text="Clicks: 0"
                       Margin="0,0,0,12" />

            <TextBlock Text="This is a UserControl without InvokePattern. click_element should fall back to mouse clicks."
                       Foreground="Gray" />
        </StackPanel>
    </Grid>
</Window>

