<Window x:Class="WpfPilot.TestApp.Scroll.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="WpfPilot Scroll TestApp"
        Width="900"
        Height="650"
        ResizeMode="NoResize"
        Topmost="True"
        WindowStartupLocation="Manual"
        Left="100"
        Top="100"
        Background="White"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="WpfPilot.TestApp.Scroll — ScrollViewer"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Margin="0,0,0,16" />

        <StackPanel Grid.Row="1" Width="520">
            <TextBlock Text="Target button is initially offscreen. Use scroll_to_element to bring it into view."
                       Foreground="Gray"
                       Margin="0,0,0,8" />

            <ScrollViewer x:Name="ScrollViewer"
                          AutomationProperties.AutomationId="Scroll_Viewer"
                          Height="420"
                          Width="520"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="0,0,0,12"
                          HorizontalAlignment="Left">
                <StackPanel x:Name="ScrollContentPanel"
                            Margin="0,0,12,0" />
            </ScrollViewer>

            <TextBlock x:Name="StatusText"
                       AutomationProperties.AutomationId="Scroll_Status"
                       Text="Clicks: 0"
                       Margin="0,0,0,12" />
        </StackPanel>
    </Grid>
</Window>

