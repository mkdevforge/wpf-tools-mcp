<Window x:Class="WpfToolsMcp.TestApp.Tabs.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="WPF Tools MCP Tabs TestApp"
        Width="900"
        Height="650"
        ResizeMode="NoResize"
        Topmost="True"
        WindowStartupLocation="Manual"
        Left="100"
        Top="100"
        Background="White"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="WpfToolsMcp.TestApp.Tabs — Tabs"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Margin="0,0,0,16" />

        <StackPanel Grid.Row="1" Width="420">
            <TabControl x:Name="TabsTabControl"
                        AutomationProperties.AutomationId="Tabs_TabControl"
                        SelectionChanged="TabsTabControl_SelectionChanged"
                        Height="480"
                        HorizontalAlignment="Left">
                <TabItem Header="Home">
                    <StackPanel Margin="12">
                        <TextBlock Text="Nested ListBox (trap):"
                                   Foreground="Gray"
                                   Margin="0,0,0,4" />
                        <ListBox Height="100"
                                 Width="240"
                                 HorizontalAlignment="Left">
                            <ListBoxItem Content="Settings" />
                            <ListBoxItem Content="About" />
                            <ListBoxItem Content="Advanced" />
                        </ListBox>
                    </StackPanel>
                </TabItem>
                <TabItem Header="Settings">
                    <TextBlock Text="Settings content"
                               Margin="12" />
                </TabItem>
                <TabItem Header="About">
                    <TextBlock Text="About content"
                               Margin="12" />
                </TabItem>
                <TabItem Header="Advanced">
                    <TextBlock Text="Advanced content"
                               Margin="12" />
                </TabItem>
            </TabControl>

            <TextBlock x:Name="TabsSelectedStatus"
                       AutomationProperties.AutomationId="Tabs_SelectedStatus"
                       Text="Selected: (none)"
                       Margin="0,12,0,0" />
        </StackPanel>
    </Grid>
</Window>

