<Window x:Class="WpfPilot.TestApp.TreeView.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="WpfPilot TreeView TestApp"
        Width="900"
        Height="650"
        ResizeMode="NoResize"
        Topmost="True"
        WindowStartupLocation="Manual"
        Left="100"
        Top="100"
        Background="White"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="WpfPilot.TestApp.TreeView — TreeView"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Margin="0,0,0,16" />

        <StackPanel Grid.Row="1" Width="420">
            <TreeView x:Name="MainTree"
                      AutomationProperties.AutomationId="Tree_TreeView"
                      SelectedItemChanged="MainTree_SelectedItemChanged"
                      Height="520"
                      HorizontalAlignment="Left">
                <TreeViewItem Header="Node 1" IsExpanded="True">
                    <TreeViewItem Header="Node 1.1" />
                    <TreeViewItem Header="Node 1.2" />
                </TreeViewItem>
                <TreeViewItem Header="Node 2" IsExpanded="True">
                    <TreeViewItem Header="Node 2.1" />
                    <TreeViewItem Header="Node 2.2" />
                </TreeViewItem>
                <TreeViewItem Header="Node 3" IsExpanded="True">
                    <TreeViewItem Header="Node 3.1" />
                    <TreeViewItem Header="Node 3.2" />
                </TreeViewItem>
            </TreeView>

            <TextBlock x:Name="TreeSelectedStatus"
                       AutomationProperties.AutomationId="Tree_SelectedStatus"
                       Text="Selected: (none)"
                       Margin="0,12,0,0" />
        </StackPanel>
    </Grid>
</Window>

