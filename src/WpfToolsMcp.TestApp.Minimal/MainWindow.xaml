<Window x:Class="WpfToolsMcp.TestApp.Minimal.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="WPF Tools MCP Minimal TestApp"
        Width="900"
        Height="650"
        ResizeMode="NoResize"
        Topmost="True"
        WindowStartupLocation="Manual"
        Left="100"
        Top="100"
        Background="White"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="WpfToolsMcp.TestApp.Minimal — No AutomationIds"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Margin="0,0,0,16" />

        <StackPanel Grid.Row="1" Width="420">
            <TextBlock Text="Buttons (name ambiguity):"
                       Foreground="Gray"
                       Margin="0,0,0,4" />
            <StackPanel Orientation="Horizontal"
                        Margin="0,0,0,8">
                <Button x:Name="PrimaryOkButton"
                        Content="OK"
                        Click="PrimaryOkButton_Click"
                        Width="120"
                        Margin="0,0,8,0"
                        HorizontalAlignment="Left" />
                <Button Content="OK"
                        Width="120"
                        HorizontalAlignment="Left" />
            </StackPanel>

            <TextBlock x:Name="ClickStatus"
                       Text="Clicks: 0"
                       Margin="0,0,0,12" />

            <TextBlock Text="ListBox (no item AutomationIds):"
                       Foreground="Gray"
                       Margin="0,0,0,4" />
            <ListBox x:Name="ItemList"
                     Height="220"
                     Width="240"
                     Margin="0,0,0,6"
                     SelectionChanged="ItemList_SelectionChanged"
                     HorizontalAlignment="Left" />

            <TextBlock x:Name="SelectionStatus"
                       Text="Selected: (none)"
                       Margin="0,0,0,12" />
        </StackPanel>
    </Grid>
</Window>

