<UserControl x:Class="WpfToolsMcp.TestApp.CustomControls.ClickableCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="80"
             d:DesignWidth="320">
    <Border x:Name="Root"
            Background="#FFEEF6FF"
            BorderBrush="#FF8AB4F8"
            BorderThickness="2"
            CornerRadius="6"
            Padding="12"
            MouseLeftButtonUp="Root_MouseLeftButtonUp">
        <StackPanel>
            <TextBlock x:Name="TitleText"
                       Text="Clickable card"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4" />
            <TextBlock x:Name="SubtitleText"
                       Text="Click me (custom control)"
                       Foreground="Gray" />
        </StackPanel>
    </Border>
</UserControl>

