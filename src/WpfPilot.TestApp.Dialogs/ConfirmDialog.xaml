<Window x:Class="WpfPilot.TestApp.Dialogs.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="WpfPilot Confirm Dialog"
        Width="520"
        Height="260"
        ResizeMode="NoResize"
        Topmost="True"
        WindowStartupLocation="Manual"
        Left="140"
        Top="140"
        Background="White"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Confirm?"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12" />

        <TextBlock Grid.Row="1"
                   Text="This is a modal dialog window."
                   Foreground="Gray" />

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    Margin="0,16,0,0">
            <Button AutomationProperties.AutomationId="Dialog_OK"
                    Content="OK"
                    Width="120"
                    Margin="0,0,8,0"
                    Click="Ok_Click" />
            <Button AutomationProperties.AutomationId="Dialog_Cancel"
                    Content="Cancel"
                    Width="120"
                    Click="Cancel_Click" />
        </StackPanel>
    </Grid>
</Window>

